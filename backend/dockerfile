FROM python:3.12-windowsservercore-ltsc2022

# 1. ตั้งค่า Environment พื้นฐาน
ENV PYTHONUTF8=1
WORKDIR C:/MicrosoftScanEngine/backend

# 2. ติดตั้ง Dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir openpyxl bcrypt==4.0.1

# 3. ตั้งค่า WinRM พื้นฐานตอน Build (เพื่อให้ System Registry เปลี่ยนค่า)
RUN powershell -Command " \
    Set-Item WSMan:\localhost\Client\TrustedHosts -Value '*' -Force; \
    winrm set winrm/config/client/auth '@{Basic=\"true\"}'; \
    winrm set winrm/config/client '@{AllowUnencrypted=\"true\"}'"

# 4. ก๊อปปี้โค้ดทั้งหมด
COPY . .

EXPOSE 8000

# 5. ส่วน Runtime: ใส่ Semicolon (;) ให้ครบทุกคำสั่ง
CMD ["powershell", "-Command", " \
    # 1. บังคับเปิด Service และรอจนกว่าจะ Running จริง \
    Set-Service WinRM -StartupType Automatic; \
    Start-Service WinRM; \
    while ((Get-Service WinRM).Status -ne 'Running') { Start-Sleep -Seconds 1 }; \
    \
    # 2. ตั้งค่าผ่าน Registry และ winrm set (แบบรวบตึง) \
    Write-Host 'Configuring WinRM Client...'; \
    winrm set winrm/config/client '@{AllowUnencrypted=\"true\"}'; \
    winrm set winrm/config/client/auth '@{Basic=\"true\"}'; \
    Set-Item WSMan:\localhost\Client\TrustedHosts -Value '*' -Force; \
    \
    # 3. เช็คตัวแปร (ถ้าว่างให้หยุดรอเพื่อ Debug) \
    if (-not $env:WINRM_PASS) { Write-Error 'WINRM_PASS is EMPTY!'; exit 1 }; \
    \
    # 4. วอร์มอัพ (ใส่ Loop ลองใหม่ 3 ครั้ง ถ้าครั้งแรกไม่ติด) \
    $pass = ConvertTo-SecureString $env:WINRM_PASS -AsPlainText -Force; \
    $cred = New-Object System.Management.Automation.PSCredential($env:WINRM_USER, $pass); \
    \
    for ($i=1; $i -le 3; $i++) { \
        try { \
            Write-Host \"Attempt $i: Warming up WinRM to 192.168.105.11...\"; \
            Test-WSMan -ComputerName '192.168.105.11' -Authentication Basic -Credential $cred -ErrorAction Stop; \
            Write-Host 'WinRM Connected Successfully!' -ForegroundColor Green; \
            break; \
        } catch { \
            Write-Warning \"Attempt $i failed: $($_.Exception.Message)\"; \
            Start-Sleep -Seconds 5; \
            
        } \
    } \
    \
    # 5. รันแอปพลิเคชัน \
    Write-Host 'Starting Uvicorn...'; \
    python -m uvicorn main:app --host 0.0.0.0 --port 8000"]